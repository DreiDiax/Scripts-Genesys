SELECT * FROM (
    SELECT DISTINCT ON (cd.conversationid)
        cd.conversationid,
        to_char(cd.conversationstart, 'dd/mm/yyyy') as "Fecha de envío",
        cd.wrapupcodename as tipificacion,
        right(cd.dnis,12) as telefono,
        (SELECT value 
         FROM gns_purecloud.conversation_attributes ca2 
         WHERE ca2.conversationid = cd.conversationid 
         AND ca2.key in ('IdCita', 'dialerContactId')
         LIMIT 1) as id_cita
    FROM gns_purecloud.conversations_details cd
    WHERE cd.conversationid IN (
        SELECT DISTINCT ca.conversationid 
        FROM gns_purecloud.conversation_attributes ca 
        WHERE ca.key = 'dialerCampaignId'
        AND ca.participantstarttime >= '2026-04-01'
        AND ca.value = 'e685438d-4e65-4ecc-9893-fe0190a39f76'
    )
    AND cd.segmenttype = 'wrapup'
    ORDER BY 
        cd.conversationid,
        CASE 
            WHEN cd.wrapupcodename = 'Outbound - IVR - ConfirmaCita' THEN 1
            WHEN cd.wrapupcodename = 'Outbound - IVR - RechazaCita' THEN 2
            WHEN cd.wrapupcodename = 'Outbound - IVR - Inicio' THEN 3
            WHEN cd.wrapupcodename NOT LIKE 'ININ%' THEN 4
            ELSE 5
        END
) sub
ORDER BY "Fecha de envío", conversationid
